rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // v1: any signed-in user can read; no client writes.
    // All mutations (ingest, enrichment, step log) go through Admin SDK
    // in server routes. Tighten to project-membership when we open up.

    match /projects/{pid} {
      allow read: if request.auth != null;
      allow write: if false;

      match /rows/{rowId} {
        allow read: if request.auth != null;
        allow write: if false;

        match /steps/{stepId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }
    }

    // Required for collectionGroup('steps') queries (e.g. the dashboard
    // live log). Nested match rules above only grant access via the
    // scoped parent path; group queries bypass that scoping and need an
    // explicit wildcard rule here.
    match /{path=**}/steps/{stepId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
