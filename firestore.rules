rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // v1: any signed-in user can read; no client writes.
    // All mutations (ingest, enrichment, step log) go through Admin SDK
    // in server routes. Tighten to project-membership when we open up.

    match /projects/{pid} {
      allow read: if request.auth != null;
      allow write: if false;

      match /rows/{rowId} {
        allow read: if request.auth != null;
        allow write: if false;

        match /steps/{stepId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }
    }
  }
}
