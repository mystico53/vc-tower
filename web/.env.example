# --- Firebase: Web SDK (client) ------------------------------------------
# Safe to expose — these identify the project; access is enforced by rules.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=vc-tower.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=vc-tower
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=vc-tower.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase: Admin SDK (server) ----------------------------------------
# Used by /api/* route handlers. Local dev: point GOOGLE_APPLICATION_CREDENTIALS
# at the service account JSON that already exists at the repo root
# (vc-tower-firebase-adminsdk-fbsvc-*.json).
# In Firebase App Hosting / GCP deployment, leave these blank — the Admin SDK
# picks up the runtime service account automatically.
GOOGLE_APPLICATION_CREDENTIALS=C:\\coding\\vc-tower\\vc-tower-firebase-adminsdk-fbsvc-e9feffcf9d.json
FIREBASE_PROJECT_ID=vc-tower
# Optional fallback if you prefer inlining the key instead of using the JSON
# path above. PRIVATE_KEY must keep the literal \n escapes from the JSON.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Ingest -------------------------------------------------------------
# Shared secret required as 'x-ingest-token' header when POSTing /api/ingest.
INGEST_TOKEN=change-me
# Absolute path to the SQLite masterlist produced by
# scripts/build_masterlist.py.
MASTERLIST_DB_PATH=C:\\coding\\vc-tower\\data\\masterlist.db

# --- Qwen 3.5 Plus (DashScope, Singapore endpoint) ----------------------
# Used by the orchestrator + extractor in PR #2.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Pin exact snapshot, not alias, so behavior doesn't silently drift.
DASHSCOPE_MODEL=qwen-plus-2025-09-11

# --- Enrichment tools (PR #2) -------------------------------------------
FIRECRAWL_API_KEY=

APIFY_TOKEN=
APIFY_LINKEDIN_PROFILE_ACTOR=supreme_coder/linkedin-profile-scraper
APIFY_LINKEDIN_COMPANY_ACTOR=data-slayer/linkedin-company-scraper

XAI_API_KEY=
XAI_MODEL=grok-4-1-fast

# --- Per-row orchestrator budget (PR #2) --------------------------------
STEP_MAX_PER_ROW=5
STEP_BUDGET_CENTS_PER_ROW=10

# --- Dev-only harness ---------------------------------------------------
# /api/step/harness is a dev-only endpoint that lets a local tester drive
# multi-step enrichment runs programmatically. It refuses in NODE_ENV=production
# AND requires a matching x-dev-key header. Leave blank to disable entirely.
HARNESS_DEV_KEY=
